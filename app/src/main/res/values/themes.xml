<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SddMarketplace" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.SddMarketplace.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFF8F9</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenBrandingImage">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.SddMarketplace</item>
    </style>
</resources>
